{
  "name": "oh-my-qwen",
  "version": "0.1.0",
  "description": "Multi-agent orchestration framework for Qwen Code",
  "type": "module",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "omq": "./dist/cli/index.js",
    "oh-my-qwen": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "build:check": "npx tsc --noEmit",
    "start": "npx tsx src/cli/index.ts",
    "dev": "npx tsx src/cli/index.ts",
    "lint": "npx eslint src/ mcp-server/ hooks/scripts/",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "keywords": [
    "qwen",
    "agent",
    "orchestration",
    "multi-agent",
    "qwen-code"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "jsonc-parser": "^3.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.x",
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.x",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
